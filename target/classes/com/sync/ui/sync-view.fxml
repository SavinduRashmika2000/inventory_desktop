<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.sync.ui.MainController" stylesheets="@style.css" styleClass="main-container"
      prefHeight="850.0" prefWidth="1100.0">
    
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-box">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Data Nexus Sync" styleClass="header-title">
                <font>
                    <Font name="System Bold" size="32.0"/>
                </font>
            </Label>
            <Label text="Enterprise Database Synchronization Engine" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
        </VBox>
        <Label fx:id="statusLabel" text="Active / Online" id="statusLabel"/>
    </HBox>

    <VBox spacing="20.0" VBox.vgrow="ALWAYS" styleClass="glass-pane">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
        </padding>
        
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Detected Entities" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="12.0">
                <Button fx:id="startBtn" text="▶ Start" onAction="#handleStart" styleClass="btn-primary" disable="true"/>
                <Button fx:id="stopBtn" text="⏸ Stop" onAction="#handleStop" styleClass="btn-danger"/>
                <Button onAction="#handleForceSync" text="⚡ Force Sync" styleClass="btn-accent"/>
            </HBox>
        </HBox>

        <TableView fx:id="tablesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="tableNameCol" prefWidth="300.0" text="Table Entity"/>
                <TableColumn fx:id="processedCol" prefWidth="180.0" text="Synced Records"/>
                <TableColumn fx:id="totalCol" prefWidth="180.0" text="Total Delta"/>
                <TableColumn fx:id="statusCol" prefWidth="300.0" text="Sync Intelligence Status"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <VBox spacing="10.0" prefHeight="250.0">
        <Label text="Production Engine Output" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-transform: uppercase;"/>
        <TextArea fx:id="logArea" editable="false" VBox.vgrow="ALWAYS" wrapText="true" styleClass="log-area"/>
    </VBox>

</VBox>
