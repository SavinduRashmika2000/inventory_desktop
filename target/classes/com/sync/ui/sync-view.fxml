<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="30.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.sync.ui.MainController" stylesheets="@style.css" styleClass="main-container"
      prefHeight="850.0" prefWidth="1100.0">
    
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <!-- Premium Header Strip -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-box">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Data Nexus Sync" styleClass="header-title"/>
            <Label text="Enterprise Database Synchronization Engine" styleClass="header-subtitle"/>
        </VBox>
        <Label fx:id="statusLabel" text="Active / Online" styleClass="status-pill"/>
    </HBox>

    <!-- Main Content Area -->
    <VBox spacing="25.0" VBox.vgrow="ALWAYS" styleClass="glass-pane">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
        </padding>
        
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Database Entities" styleClass="section-header"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="12.0">
                <Button fx:id="startBtn" text="▶ Start Sync" onAction="#handleStart" styleClass="btn-primary" disable="true"/>
                <Button fx:id="stopBtn" text="⏸ Stop" onAction="#handleStop" styleClass="btn-danger"/>
                <Button onAction="#handleForceSync" text="⚡ Force Update" styleClass="btn-accent"/>
            </HBox>
        </HBox>

        <TableView fx:id="tablesTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="tableNameCol" prefWidth="300.0" text="Entity Name"/>
                <TableColumn fx:id="processedCol" prefWidth="180.0" text="Synced Records"/>
                <TableColumn fx:id="totalCol" prefWidth="180.0" text="Total Delta"/>
                <TableColumn fx:id="statusCol" prefWidth="300.0" text="Sync Status"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Terminal/Log Area -->
    <VBox spacing="10.0" prefHeight="220.0">
        <Label text="Engine Activity Stream" styleClass="activity-header"/>
        <TextArea fx:id="logArea" editable="false" VBox.vgrow="ALWAYS" wrapText="true" styleClass="log-area"/>
    </VBox>

</VBox>
